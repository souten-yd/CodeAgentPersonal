# syntax=docker/dockerfile:1.7

########################################
# Builder stage: compile llama.cpp with CUDA
########################################
FROM nvidia/cuda:12.8.0-cudnn-devel-ubuntu22.04 AS builder

# Keep apt non-interactive for deterministic CI/container builds.
ENV DEBIAN_FRONTEND=noninteractive

# Install only build-time dependencies needed for llama.cpp.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        libcurl4-openssl-dev \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src

# Clone latest llama.cpp from the official upstream repository.
RUN git clone --depth 1 https://github.com/ggml-org/llama.cpp.git

WORKDIR /src/llama.cpp

# Configure a Release CUDA build with server and curl support.
RUN cmake -S . -B build \
      -DGGML_CUDA=ON \
      -DCMAKE_CUDA_ARCHITECTURES=native \
      -DCMAKE_BUILD_TYPE=Release \
      -DLLAMA_CURL=ON \
      -DLLAMA_SERVER=ON

# Build binaries using all available CPU cores.
RUN cmake --build build --config Release -j"$(nproc)"

########################################
# Runtime stage: lightweight CUDA runtime image
########################################
FROM nvidia/cuda:12.8.0-cudnn-runtime-ubuntu22.04 AS runtime

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Install runtime dependencies only:
# - Python 3.11 (for CodeAgent runtime utilities)
# - pip (to install FastAPI, uvicorn, etc. from requirements.txt)
# - libcurl4 (required by llama.cpp with LLAMA_CURL=ON)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        software-properties-common \
        libcurl4 \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-venv \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Ensure `python` / `python3` execute Python 3.11.
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && ln -sf /usr/bin/python3.11 /usr/bin/python

# Install Python packages used by this repository (fastapi, uvicorn, etc.).
COPY requirements.txt /app/requirements.txt
RUN python3.11 -m pip install --upgrade pip \
    && python3.11 -m pip install -r /app/requirements.txt

# Create a model mount point (e.g. -v /path/to/models:/models).
RUN mkdir -p /models

# Copy compiled executables into PATH.
COPY --from=builder /src/llama.cpp/build/bin/llama-cli /usr/local/bin/llama-cli
COPY --from=builder /src/llama.cpp/build/bin/llama-server /usr/local/bin/llama-server

# Copy shared libraries produced during build.
COPY --from=builder /src/llama.cpp/build/*.so* /usr/local/lib/

# Refresh dynamic linker cache for copied shared objects.
RUN ldconfig

# llama-server default API port.
EXPOSE 8080

# Default server startup parameters for RunPod/GPU containers.
CMD ["llama-server", "--host", "0.0.0.0", "--port", "8080"]
