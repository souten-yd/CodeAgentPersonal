# syntax=docker/dockerfile:1.7

########################################
# Builder stage: either download CUDA prebuilt OR compile from source
########################################
FROM nvidia/cuda:12.8.0-cudnn-devel-ubuntu22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /src

# Optional prebuilt tar.gz URL.
# When empty, build from source.
ARG LLAMA_PREBUILT_URL=""
ARG LLAMA_CUDA_FLAGS="-Wno-deprecated-gpu-targets"

# Install tooling needed for either path (download or source build).
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        ninja-build \
        git \
        curl \
        tar \
        libcurl4-openssl-dev \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Produce a common artifact layout under /opt/llama-dist:
# /opt/llama-dist/bin/llama-server, /opt/llama-dist/bin/llama-cli, and optional *.so files.
RUN if [ -n "${LLAMA_PREBUILT_URL}" ]; then \
      echo "[builder] Using prebuilt package: ${LLAMA_PREBUILT_URL}"; \
      mkdir -p /tmp/extract; \
      curl -fL --retry 3 --retry-delay 2 "${LLAMA_PREBUILT_URL}" -o /tmp/llama-prebuilt.tar.gz; \
      tar -xzf /tmp/llama-prebuilt.tar.gz -C /tmp/extract; \
      ROOT="$(find /tmp/extract -mindepth 1 -maxdepth 1 -type d | head -n 1)"; \
      if [ -z "${ROOT}" ]; then ROOT="/tmp/extract"; fi; \
      mkdir -p /opt/llama-dist/bin; \
      cp -a "${ROOT}/bin/." /opt/llama-dist/bin/; \
      if ls "${ROOT}"/*.so* >/dev/null 2>&1; then cp -a "${ROOT}"/*.so* /opt/llama-dist/; fi; \
    else \
      echo "[builder] No prebuilt URL provided; compiling llama.cpp from source."; \
      git clone --depth 1 https://github.com/ggml-org/llama.cpp.git /src/llama.cpp; \
      cmake -S /src/llama.cpp -B /src/llama.cpp/build -G Ninja \
        -DGGML_CUDA=ON \
        -DCMAKE_CUDA_ARCHITECTURES=native \
        -DCMAKE_CUDA_FLAGS="${LLAMA_CUDA_FLAGS}" \
        -DCMAKE_BUILD_TYPE=Release \
        -DLLAMA_CURL=ON \
        -DLLAMA_SERVER=ON \
        -DLLAMA_BUILD_TESTS=OFF; \
      cmake --build /src/llama.cpp/build --config Release -j"$(nproc)"; \
      mkdir -p /opt/llama-dist/bin; \
      cp -a /src/llama.cpp/build/bin/. /opt/llama-dist/bin/; \
      if ls /src/llama.cpp/build/*.so* >/dev/null 2>&1; then cp -a /src/llama.cpp/build/*.so* /opt/llama-dist/; fi; \
    fi

########################################
# Runtime stage: CUDA runtime + Python3.11 + pip deps
########################################
FROM nvidia/cuda:12.8.0-cudnn-runtime-ubuntu22.04 AS runtime

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        software-properties-common \
        libcurl4 \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-venv \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && ln -sf /usr/bin/python3.11 /usr/bin/python

COPY requirements.txt /app/requirements.txt
RUN python3.11 -m pip install --upgrade pip \
    && python3.11 -m pip install -r /app/requirements.txt

RUN mkdir -p /models

COPY --from=builder /opt/llama-dist /app/llama
RUN cp /app/llama/bin/llama-cli /usr/local/bin/llama-cli \
    && cp /app/llama/bin/llama-server /usr/local/bin/llama-server \
    && if ls /app/llama/*.so* >/dev/null 2>&1; then cp -a /app/llama/*.so* /usr/local/lib/; fi \
    && ldconfig

EXPOSE 8080
CMD ["llama-server", "--host", "0.0.0.0", "--port", "8080"]
