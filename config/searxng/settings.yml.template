use_default_settings: true

general:
  instance_name: "CodeAgent SearXNG"

search:
  formats:
    - html
    - json

server:
  bind_address: "__SEARXNG_BIND_ADDRESS__"
  port: __SEARXNG_PORT__
  base_url: "__SEARXNG_BASE_URL__"
  secret_key: "__SEARXNG_SECRET_KEY__"

# Runpod / single-container mode:
# Disable redis-dependent limiter by default to keep runtime lightweight.
botdetection:
  ip_limit:
    link_token: false
  ip_lists:
    block_ip: []
